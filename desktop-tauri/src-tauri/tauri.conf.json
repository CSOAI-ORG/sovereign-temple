{
  "build": {
    "beforeBuildCommand": "cd ../meokclaw-v2 && npm run build",
    "beforeDevCommand": "cd ../meokclaw-v2 && npm run dev",
    "devPath": "http://localhost:3000",
    "distDir": "../meokclaw-v2/dist"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true
      },
      "http": {
        "all": false,
        "request": true
      },
      "notification": {
        "all": true
      },
      "os": {
        "all": true
      },
      "process": {
        "all": false,
        "relaunch": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Productivity",
      "copyright": "CSOAI ORG",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.csoai.meokclaw",
      "longDescription": "MEOKCLAW Sovereign Intelligence OS — Multi-model AI with council mode, cost optimization, and 15-language support.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Sovereign AI OS",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https:; img-src 'self' data: https:; font-src 'self' data:;"
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://api.meokclaw.io/updater/{{target}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5QzY2QzE1QjU0QjU1NDMK"
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "MEOKCLAW v2.4",
        "width": 1400,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ]
  }
}

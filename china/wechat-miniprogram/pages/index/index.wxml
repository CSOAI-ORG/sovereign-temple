<!--
  MEOKCLAW 微信小程序 — 对话页面 markup
  设计风格：简洁现代，符合中国用户审美习惯
-->

<view class="chat-container">
  <!-- 顶部导航栏 -->
  <view class="chat-header">
    <text class="header-title">MEOKCLAW 智能对话</text>
    <picker mode="selector" range="{{['DeepSeek Flash', 'Kimi K2.6', 'Qwen 3', 'Ernie 4.5']}}" bindchange="onModelChange">
      <view class="model-selector">
        <text class="model-label">模型</text>
        <text class="model-name">{{currentModel}}</text>
      </view>
    </picker>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{scrollToBottom}}"
    enhanced
    show-scrollbar
  >
    <block wx:for="{{messages}}" wx:key="id">
      <!-- 用户消息 -->
      <view wx:if="{{item.role === 'user'}}" class="message-row user-row" id="msg_{{item.id}}">
        <view class="message-bubble user-bubble">
          <text class="message-text">{{item.content}}</text>
        </view>
        <view class="avatar user-avatar">
          <text class="avatar-text">我</text>
        </view>
      </view>

      <!-- 助手消息 -->
      <view wx:elif="{{item.role === 'assistant'}}" class="message-row assistant-row" id="msg_{{item.id}}">
        <view class="avatar assistant-avatar">
          <text class="avatar-text">议</text>
        </view>
        <view class="message-bubble assistant-bubble" bindlongpress="onMessageLongPress" data-content="{{item.content}}">
          <text class="message-text">{{item.content}}</text>
          <view wx:if="{{showCostInfo && item.cost > 0}}" class="cost-tag">
            <text class="cost-text">{{item.model}} · ¥{{(item.cost * 7.2).toFixed(4)}} · {{item.latencyMs}}ms</text>
          </view>
        </view>
      </view>

      <!-- 错误消息 -->
      <view wx:elif="{{item.role === 'error'}}" class="message-row error-row" id="msg_{{item.id}}">
        <view class="error-bubble">
          <text class="error-text">{{item.content}}</text>
        </view>
      </view>
    </block>

    <!-- 加载中指示器 -->
    <view wx:if="{{isLoading}}" class="loading-row">
      <view class="loading-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
      <text class="loading-text">思考中...</text>
    </view>

    <!-- 底部占位 -->
    <view id="bottom-anchor"></view>
  </scroll-view>

  <!-- 快捷操作栏 -->
  <view class="quick-actions">
    <view class="quick-btn" bindtap="goToCouncil">
      <text class="quick-btn-icon">🏛️</text>
      <text class="quick-btn-text">议会模式</text>
    </view>
    <view class="quick-btn">
      <text class="quick-btn-icon">🛡️</text>
      <text class="quick-btn-text">安全审查</text>
    </view>
    <view class="quick-btn">
      <text class="quick-btn-icon">📊</text>
      <text class="quick-btn-text">成本报告</text>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-area">
    <!-- 语音按钮 -->
    <view
      class="voice-btn {{isRecording ? 'recording' : ''}}"
      bindtouchstart="onTouchStartRecord"
      bindtouchend="onTouchEndRecord"
    >
      <text class="voice-icon">🎤</text>
    </view>

    <!-- 文本输入 -->
    <view class="input-wrapper">
      <textarea
        class="message-input"
        value="{{inputValue}}"
        bindinput="onInputChange"
        placeholder="请输入您的问题..."
        placeholder-class="input-placeholder"
        maxlength="2000"
        auto-height
        confirm-type="send"
        bindconfirm="sendMessage"
      />
    </view>

    <!-- 发送按钮 -->
    <view class="send-btn {{inputValue.length > 0 ? 'active' : ''}}" bindtap="sendMessage">
      <text class="send-icon">发送</text>
    </view>
  </view>

  <!-- 录音提示 -->
  <view wx:if="{{isRecording}}" class="recording-toast">
    <view class="recording-wave">
      <view class="wave-bar"></view>
      <view class="wave-bar"></view>
      <view class="wave-bar"></view>
      <view class="wave-bar"></view>
      <view class="wave-bar"></view>
    </view>
    <text class="recording-text">正在聆听...</text>
    <text class="recording-hint">松开发送</text>
  </view>
</view>
